{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "YourCoach Integration Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "contextual": {
    "display": "header",
    "options": ["copy", "view", "chatgpt", "claude", "assistant"]
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "prerequisites"]
          },
          {
            "group": "Architecture",
            "pages": ["architecture/sequence-flow"]
          },
          {
            "group": "Widget integration",
            "pages": ["widget/integration", "widget/webview", "widget/events"]
          },
          {
            "group": "Push notifications",
            "pages": ["push-notifications/webhook", "push-notifications/events"]
          },
          {
            "group": "Reports & analytics",
            "pages": ["reports"]
          },
          {
            "group": "Code scripts",
            "pages": ["scripts/key-generation", "scripts/jwt-generation"]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Widget protocol",
            "pages": ["api-reference/widget-messages"]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoints/external-auth",
              "api-reference/endpoints/check-status",
              "api-reference/endpoints/eligibility",
              "api-reference/endpoints/update-profile",
              "api-reference/endpoints/create-lead"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/yc-text-logo.svg",
    "dark": "/logo/yc-text-logo.svg"
  },
  "navbar": {
    "links": []
  },
  "footer": {
    "socials": {}
  },
  "redirects": [
    { "source": "/widget/environments", "destination": "/widget/integration" },
    {
      "source": "/widget/iframe-embedding",
      "destination": "/widget/integration"
    },
    {
      "source": "/widget/initialization",
      "destination": "/widget/integration"
    },
    { "source": "/mobile/ios", "destination": "/widget/webview" },
    { "source": "/mobile/android", "destination": "/widget/webview" }
  ]
}
